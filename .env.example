# Flask
SECRET_KEY=change-me-to-a-random-string

# QQ 邮箱配置
QQ_SENDER_EMAIL=your-qq-email@qq.com
QQ_AUTH_CODE=your-16-char-auth-code

# 接收报告的邮箱
ADMIN_EMAIL=admin@qq.com

# 监控 API 密钥（随机字符串，用于保护 API 端点）
MONITOR_API_KEY=change-me-to-a-random-string-at-least-32-chars

# 监控窗口天数（默认 5 天）
MONITOR_WINDOW_DAYS=3
